{
  "name": "ledger",
  "version": "0.4.5",
  "description": "The Bean Counter — uncompromising Financial Architect. Exact Money, double-entry, validated ledgers, canon citations. The best financial construct is the one that cannot be wrong.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "examples",
    "skills",
    "commands",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "tsx scripts/verify-determinism.ts",
    "check:persona": "tsx scripts/check-persona-consistency.ts",
    "verify:full": "npm run build && npm run typecheck && npm test && npm run verify && npm run check:persona",
    "clean": "node --eval \"const fs=require('fs'); try{fs.rmSync('dist',{recursive:true,force:true});}catch(e){}\" ",
    "prepublishOnly": "npm run clean && npm run verify:full"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eternal-roman/ledger.git"
  },
  "keywords": [
    "ledger",
    "accounting",
    "double-entry",
    "fintech",
    "deterministic",
    "exact-arithmetic",
    "ai-skill",
    "financial-systems",
    "bean-counter"
  ],
  "author": "eternal-roman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eternal-roman/ledger/issues"
  },
  "homepage": "https://github.com/eternal-roman/ledger#readme",
  "dependencies": {
    "decimal.js": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  }
}
