#!/usr/bin/env bash
# ledger-activate — bash activation hook for Ledger kernel
# Primary rules come from AGENTS.md + skills/ledger/SKILL.md
#
# This is the recommended bash version.
# Works with Git Bash on Windows, and native bash on macOS/Linux.
#
# Compatible with the run-hook.cmd polyglot wrapper for cross-platform support.

set -euo pipefail

echo 'Ledger kernel active.'
echo 'Rules: Zero-Skip ladder + Canonical Financial Artifact + no floats + double-entry proof.'
echo 'Use /ledger-verify, /ledger-audit, /ledger-review (or host equivalents) before shipping. Enforce exact balanced results.'

exit 0
